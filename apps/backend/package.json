{
  "name": "@ch-alpineroute/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "import:destinations": "tsx src/scripts/import-destinations.ts",
    "import:destinations-legacy": "tsx src/scripts/import-destinations-legacy.ts",
    "import:hiking-routes": "tsx src/scripts/import-hiking-routes.ts",
    "import:slf-regions": "tsx src/scripts/import-slf-regions.ts",
    "worker:live": "tsx src/workers/liveStatus.worker.ts",
    "worker:trend": "tsx src/workers/trend.worker.ts"
  },
  "dependencies": {
    "@ch-alpineroute/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.15",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
